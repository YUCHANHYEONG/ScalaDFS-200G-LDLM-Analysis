# Directories building kernel modules should have two files:
#
# Makefile.in:
#
# MODULES := <module-name>
# <module-name>-objs := file1.o file2.o file3.o
# include /root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/Rules
#
# and autoMakefile.am:
#
# if MODULES
# modulefs_DATA = <module-name>$(KMODEXT)
# endif
#
# DIST_SOURCES = $(<module-name>-objs:.o=.c) <other sources>
# MOSTLYCLEANFILES = *.o *.ko *.mod.c

ifeq ($(PATCHLEVEL),)

include autoMakefile

fix-kext-ownership:
	@if test -d $(DESTDIR)$(kextdir) ; then \
		echo chown -R root:wheel $(DESTDIR)$(kextdir) ; \
		chown -R root:wheel $(DESTDIR)$(kextdir) || \
			echo >&2 "*** WARNING: Could not fix kext ownership for $(DESTDIR)$(kextdir)" ; \
	fi

else

include /root/workspace_ych/FAST27/scaladfs-thread-model/linux-kernel/.config

EXTRA_CFLAGS := $(EXTRA_PRE_CFLAGS)
EXTRA_CFLAGS += -include /root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/undef.h -include /root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/config.h  -g -I/root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/libcfs/include -I/root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/libcfs/include/libcfs -I/root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/lnet/include/uapi -I/root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/lnet/include -I/root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/lustre/include/uapi -I/root/workspace_ych/FAST27/scaladfs-thread-model/lustre-sim-fifo/lustre/include -Wno-format-truncation -Wno-stringop-truncation -Wno-stringop-overflow -g -O2 -Wall -Werror 
EXTRA_CFLAGS += $(EXTRA_POST_CFLAGS)

KBUILD_EXTRA_SYMBOLS += 

obj-m += $(patsubst %,%.o,$(MODULES))

endif # PATCHLEVEL
