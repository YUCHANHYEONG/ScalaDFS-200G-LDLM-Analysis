#
# Read LLVM and LLVM_IAS env variables and set CC and friends
# based on their values
#
AC_DEFUN([LTC_LLVM_TOOLCHAIN], [
AC_ARG_VAR(LLVM, "Enable LLVM toolchain")
AC_ARG_VAR(LLVM_IAS, "Disable LLVM integrated assembler")

if [[ -n "$LLVM" ]]; then

if [[ -z "${LLVM##*/*}" ]]; then
