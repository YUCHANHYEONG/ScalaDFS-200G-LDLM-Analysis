[global]
;name=fio-rand-write
directory=/mnt/client
;directory=/mnt/beegfs
;filename=/dev/nvme0n1
;rw=write
rw=randwrite
bs=32k
direct=0
numjobs=128
;numjobs=1
;verify=meta
;time_based
;runtime=60
;runtime=30
group_reporting

[file1]
size=3G
;size=100M
;nrfiles=2
;ioengine=libaio
;ioengine=pvsync2
;hipri
;iodepth=16
