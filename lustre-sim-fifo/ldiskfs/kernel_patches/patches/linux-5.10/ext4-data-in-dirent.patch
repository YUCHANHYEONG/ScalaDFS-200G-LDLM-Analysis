 fs/ext4/ext4.h        |  100 +++++++++++++++++++++++-
 fs/ext4/fast_commit.c |    2 
 fs/ext4/inline.c      |    8 -
 fs/ext4/namei.c       |  201 +++++++++++++++++++++++++++++++++++++++-----------
 fs/ext4/super.c       |    4 
 6 files changed, 270 insertions(+), 58 deletions(-)

